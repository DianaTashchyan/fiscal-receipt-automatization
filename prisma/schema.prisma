// ============================================================
// Prisma Schema — Electronic Fiscal Receipt Service (MVP)
// PostgreSQL + Prisma ORM
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

enum PaymentMethod {
  CASH
  CARD
  MIXED
  ONLINE
}

enum ReceiptStatus {
  PENDING
  FISCALIZING
  FISCALIZED
  PDF_GENERATED
  SENT
  FAILED
}

enum DeliveryMethod {
  EMAIL
  SMS
  NONE
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  passwordHash String
  role         UserRole         @default(MANAGER)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  restaurants  UserRestaurant[]
}

model UserRestaurant {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
}

model Restaurant {
  id          String             @id @default(cuid())
  name        String
  tin         String
  crn         String?   // null until received from SRC after u6 approval
  address     String
  logoUrl     String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // ---- Per-restaurant SRC certificate (overrides global env cert) ----
  // Priority: srcCertData > srcCertPath > global env (SRC_CERT_PATH).
  // srcCertPassword is stored AES-256-GCM encrypted (CERT_ENCRYPTION_KEY).
  srcCertData      Bytes?    // PKCS#12 binary uploaded via /api/restaurants/:id/src-config
  srcCertPassword  String?   // encrypted cert password
  srcCertPath      String?   // alternative: file system path (no DB bytes)
  srcConfiguredAt  DateTime? // when the cert was last stored

  // ---- SRC cabinet registration fields (entered in SRC cabinet form u6) ----
  platformName      String?   // Software name — SRC cabinet field 5.4
  websiteUrl        String?   // HTTPS URL — SRC cabinet field 5.3
  srcIpAddress      String?   // IPv4 resolved from websiteUrl hostname (cached; cleared on URL change)

  // ---- CSR / onboarding ----
  srcPrivateKeyEnc  String?   // RSA private key, AES-256-GCM encrypted with CERT_ENCRYPTION_KEY
  srcCsrPem         String?   // PEM-format Certificate Signing Request (safe to share)
  srcCsrCreatedAt   DateTime? // when CSR was generated
  srcOnboardingStep Int?      @default(0) // 0=new … 9=complete

  users       UserRestaurant[]
  apiKeys     RestaurantApiKey[]
  cashiers    Cashier[]
  departments Department[]
  products    Product[]
  receipts    Receipt[]
}

model RestaurantApiKey {
  id           String     @id @default(cuid())
  restaurantId String
  keyHash      String     @unique
  label        String?
  isActive     Boolean    @default(true)
  lastUsedAt   DateTime?
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model Cashier {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  taxCashierId String?   // set manually from SRC cabinet after auto-provisioning
  pinCodeHash  String?   // optional — not needed for API-key-authenticated POS requests
  isDefault    Boolean    @default(false)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  receipts     Receipt[]
}

model Department {
  id              String     @id @default(cuid())
  restaurantId    String
  name            String
  taxDepartmentId String?   // set manually from SRC cabinet after auto-provisioning
  taxRegime       String?   // set manually (1=VAT, 2=VAT-exempt, 3=Turnover, 7=Micro)
  isDefault       Boolean    @default(false)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  products        Product[]
}

model Product {
  id                String        @id @default(cuid())
  restaurantId      String
  departmentId      String
  externalProductId String?
  name              String
  goodCode          String
  adgCode           String
  unit              String
  price             Decimal?      @db.Decimal(10, 2)
  isVariablePrice   Boolean       @default(false)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  restaurant        Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  department        Department    @relation(fields: [departmentId], references: [id])
  receiptItems      ReceiptItem[]

  @@index([restaurantId, externalProductId])
}

model Receipt {
  id              String         @id @default(cuid())
  restaurantId    String
  cashierId       String?
  externalOrderId String
  tableNumber     String?
  fiscalNumber    String?
  receiptNumber   String?
  qrData          String?
  qrUrl           String?

  // ---- SRC / taxservice response fields ----
  srcReceiptId    String?
  srcSn           String?
  srcTin          String?
  srcTaxpayer     String?
  srcAddress      String?
  srcFiscalTime   DateTime?
  srcTotal        Decimal?  @db.Decimal(12, 2)
  srcChange       Decimal?  @db.Decimal(12, 2)
  srcRawResponse  Json?
  srcMode         String?

  // ---- SRC payment amounts sent in the print request ----
  // Stored so retry-fiscalization can send the same amounts SRC expects.
  // paidCashAmount + paidCardAmount = billAmount (never includes tip).
  paidCashAmount  Decimal?  @db.Decimal(10, 2)
  paidCardAmount  Decimal?  @db.Decimal(10, 2)

  billAmount      Decimal        @db.Decimal(10, 2)
  tipAmount       Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal        @db.Decimal(10, 2)
  paymentMethod   PaymentMethod
  deliveryMethod  DeliveryMethod @default(NONE)
  customerEmail   String?
  customerPhone   String?
  pdfUrl          String?
  status          ReceiptStatus  @default(PENDING)
  errorMessage    String?
  retryCount      Int            @default(0)
  lastRetryAt     DateTime?
  fiscalizedAt    DateTime?
  sentAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  restaurant      Restaurant     @relation(fields: [restaurantId], references: [id])
  cashier         Cashier?       @relation(fields: [cashierId], references: [id])
  items           ReceiptItem[]
  events          ReceiptEvent[]

  @@unique([restaurantId, externalOrderId])
  @@index([status])
  @@index([restaurantId, createdAt])
}

model ReceiptItem {
  id                String   @id @default(cuid())
  receiptId         String
  productId         String?
  externalProductId String?
  name              String
  goodCode          String
  adgCode           String
  unit              String
  taxRegime         String
  departmentTaxId   String
  quantity          Decimal  @db.Decimal(10, 3)
  unitPrice         Decimal  @db.Decimal(10, 2)
  totalPrice        Decimal  @db.Decimal(10, 2)
  discountAmount    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt         DateTime @default(now())
  receipt           Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product           Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model ReceiptEvent {
  id         String         @id @default(cuid())
  receiptId  String
  event      String
  fromStatus ReceiptStatus?
  toStatus   ReceiptStatus?
  payload    Json?
  createdAt  DateTime       @default(now())
  receipt    Receipt        @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId, createdAt])
}

// ============================================================
// SRC request sequence number (seq).
// The SRC web service requires a monotonically increasing `seq`
// per CRN, shared across ALL seq-bearing methods, persisted so
// it never resets on app restart. We store the LAST used value
// per CRN and bump it atomically inside a transaction.
// ============================================================
model SrcSequence {
  crn       String   @id
  lastSeq   BigInt   @default(0)
  updatedAt DateTime @updatedAt
}
