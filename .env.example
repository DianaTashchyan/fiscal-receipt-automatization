# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/fiscal_receipt?schema=public"

# ============================================================
# Auth / app
# ============================================================
JWT_SECRET="change-me-in-production"

# ============================================================
# SRC / taxservice integration mode
# ------------------------------------------------------------
# TAX_API_MODE is the primary switch:
#   mock     -> no certificates needed, fake (but manual-shaped) responses
#   src_real -> sends real mTLS requests to the taxservice web service
# SRC_MODE is a legacy alias still honored (mock | real).
# ============================================================
TAX_API_MODE=mock
SRC_MODE=mock

# Root URLs (from the official manual). Production is the default if unset.
SRC_BASE_URL=https://ecrm.taxservice.am/taxsystem-rs-vcr
SRC_TEST_BASE_URL=https://10.3.14.123:447

# Response language: hy | en | ru
SRC_LANGUAGE=en

# ============================================================
# Per-company SRC credentials (fill in for REAL mode)
# ------------------------------------------------------------
# These come from the company's SRC cabinet (ՀՆԷՀ) after they
# register an electronic ECR via the u6 application.
# ============================================================
SRC_TIN=
SRC_CRN=
SRC_CASHIER_ID=

# ============================================================
# Certificates (REAL mode only)
# ------------------------------------------------------------
# The manual produces a Java keystore (.jks). Node's TLS stack CANNOT read
# .jks, so convert it once to PKCS#12 (.p12) with scripts/convert-jks-to-p12.sh
# and point SRC_CERT_PATH at the .p12. SRC_JKS_PATH is kept for reference only.
# ============================================================
SRC_JKS_PATH=
SRC_JKS_PASSWORD=

# The PKCS#12 bundle actually used by Node for mutual TLS:
SRC_CERT_PATH=
SRC_CERT_PASSWORD=

# SRC CA root certificate (PEM) downloaded from src.am (optional but recommended):
SRC_CA_CERT_PATH=

# Reserved (PEM key/cert split, if you prefer over .p12 — not required):
SRC_KEY_PATH=
