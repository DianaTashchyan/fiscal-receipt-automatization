# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/fiscal_receipt?schema=public"

# ============================================================
# Auth / app
# ============================================================
JWT_SECRET="change-me-in-production-use-at-least-32-random-chars"
JWT_EXPIRES_IN="8h"

# ============================================================
# Certificate encryption key
# ------------------------------------------------------------
# Used to encrypt SRC certificate passwords stored per-restaurant in the DB.
# MUST be set before uploading any restaurant certificate via
# POST /api/restaurants/:id/src-config. If this key changes, all previously
# stored certificate passwords become unreadable and must be re-uploaded.
# Defaults to JWT_SECRET if not set (not recommended for production).
# ============================================================
CERT_ENCRYPTION_KEY="change-me-use-at-least-32-random-chars"

# ============================================================
# SRC / taxservice integration mode
# ------------------------------------------------------------
# TAX_API_MODE is the primary switch:
#   mock     -> no certificates needed, fake (but manual-shaped) responses
#   src_real -> sends real mTLS requests to the taxservice web service
# SRC_MODE is a legacy alias still honored (mock | real).
# ============================================================
TAX_API_MODE=mock
SRC_MODE=mock

# ============================================================
# Outbound IP — required for SRC u6 cabinet registration
# ------------------------------------------------------------
# The static public IPv4 address that the SRC web service will
# see when this server connects to taxservice.am.
# Shown in Step 3 of the onboarding wizard (field 5.2 in the
# SRC u6 form). If not set, the server attempts auto-detection
# via api.ipify.org (suitable for dev; use explicit value in prod).
# ============================================================
# OUTBOUND_IP=1.2.3.4

# Root URLs (from the official manual). Production is the default if unset.
SRC_BASE_URL=https://ecrm.taxservice.am/taxsystem-rs-vcr
SRC_TEST_BASE_URL=https://10.3.14.123:447

# Response language: hy | en | ru
SRC_LANGUAGE=en

# ============================================================
# Per-company SRC credentials (fill in for REAL mode)
# ------------------------------------------------------------
# These come from the company's SRC cabinet (ՀՆԷՀ) after they
# register an electronic ECR via the u6 application.
#
# SRC_TIN         : 8-digit taxpayer identification number (ՀՎՀՀ)
# SRC_CRN         : Cash register number issued by SRC (ՀԴՄ)
# SRC_CASHIER_ID  : Default cashier ID from the SRC u6 application
# ============================================================
SRC_TIN=
SRC_CRN=
SRC_CASHIER_ID=

# ============================================================
# Certificates (REAL mode only)
# ------------------------------------------------------------
# The SRC manual produces a Java keystore (.jks). Node's TLS stack CANNOT read
# .jks, so convert it once to PKCS#12 (.p12) with scripts/convert-jks-to-p12.sh
# and point SRC_CERT_PATH at the .p12. SRC_JKS_PATH is kept for reference only.
#
# Minimal required set for real mode:
#   SRC_CERT_PATH      path to the .p12 file
#   SRC_CERT_PASSWORD  password chosen when creating the .p12
# ============================================================
SRC_JKS_PATH=
SRC_JKS_PASSWORD=

# The PKCS#12 bundle actually used by Node for mutual TLS:
SRC_CERT_PATH=src-certificates/<TIN>/<TIN>.p12
SRC_CERT_PASSWORD=

# SRC CA root certificate (PEM) downloaded from src.am (optional but recommended):
SRC_CA_CERT_PATH=

# Reserved (PEM key/cert split, if you prefer over .p12 — not required):
SRC_KEY_PATH=

# ============================================================
# Email delivery (SMTP)
# ------------------------------------------------------------
# Required to send fiscal receipts by email.
# Leave blank to disable email delivery (routes return 501).
# Common providers: Gmail (smtp.gmail.com:587), Mailgun, SendGrid.
# ============================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM="Fiscal Receipt Service <noreply@example.com>"

# ============================================================
# Seed control
# ------------------------------------------------------------
# Set SEED_FORCE=true to run the seed script in production/real mode.
# NOT recommended — the seed creates demo data (fake TIN, CRN, products).
# ============================================================
# SEED_FORCE=true

# ============================================================
# SMS delivery (not yet integrated)
# ------------------------------------------------------------
# No SMS provider is wired up. To enable SMS:
#   1. Install a provider SDK (e.g. twilio)
#   2. Add provider-specific vars here
#   3. Implement the send logic in /api/receipts/[id]/send-sms/route.ts
# ============================================================
# SMS_PROVIDER_ACCOUNT_SID=
# SMS_PROVIDER_AUTH_TOKEN=
# SMS_FROM_NUMBER=
